metrics_table <- bind_rows(
calculate_spatial_metrics(mkhi_df, "Mkhitaryan (CAM)"),
calculate_spatial_metrics(auba_df, "Aubameyang (ST)"),
calculate_spatial_metrics(weigl_df, "Weigl (CDM)"),
calculate_spatial_metrics(hummels_df, "Hummels (CB)")
) %>% mutate(Centroid_X = round(Centroid_X, 1), Centroid_Y = round(Centroid_Y, 1), Zone14_Value = round(Zone14_Value, 0))
write.csv(metrics_table, "output_figures/Player_Core_Spatial_Metrics.csv", row.names = FALSE)
# 扰动比例
perturbations <- c(-0.20, -0.10, 0, 0.10, 0.20)
parameters_to_test <- c("s_base", "w_space", "c_pressure", "q_height")
# 标签
param_labels <- c(
"s_base" = "Base Tactical Score (s_base)",
"w_space" = "Spatial Weight (w_space)",
"c_pressure" = "Pressure Reward (c_pressure)",
"q_height" = "Pass Height Penalty (q_height)"
)
# 创建一个空的列表来存储每次循环的结果
sensitivity_list <- list()
print("开始执行多维度参数敏感性分析...")
for (param in parameters_to_test) {
for (p in perturbations) {
# 重新计算 Z 值，精准施加扰动
temp_data <- final_model_data %>%
mutate(
# 1. 如果当前测的是 s_base，所有基础分浮动
adj_s_base = ifelse(param == "s_base", s_base * (1 + p), s_base),
# 2. 如果测的是 w_space，空间权重浮动
adj_w_space = ifelse(param == "w_space", w_space * (1 + p), w_space),
# 3. 如果测的是 c_pressure，仅对受压迫时设定的 1.5 施加扰动，常规 1.0 不变
adj_c_pressure = case_when(
param == "c_pressure" & under_pressure == TRUE ~ 1.5 * (1 + p),
TRUE ~ c_pressure
),
# 4. 如果测的是 q_height，仅对主观设定的高空球(0.8)和低平球(0.9)施加扰动
adj_q_height = case_when(
param == "q_height" & type.name == "Pass" & pass.height.name == "High Pass" ~ 0.8 * (1 + p),
param == "q_height" & type.name == "Pass" & pass.height.name == "Low Pass" ~ 0.9 * (1 + p),
TRUE ~ q_height
),
# 重新合成最终的 Z 值
adjusted_value_z = adj_s_base * adj_w_space * adj_c_pressure * adj_q_height
)
# 提取评估指标存入列表
sensitivity_list[[paste(param, p, sep="_")]] <- data.frame(
Parameter = param,
Parameter_CN = param_labels[param],
Perturbation = p,
Perturbation_Label = factor(paste0(p * 100, "%"), levels = c("-20%", "-10%", "0%", "10%", "20%")),
Mean_Z = mean(temp_data$adjusted_value_z, na.rm = TRUE),
SD_Z = sd(temp_data$adjusted_value_z, na.rm = TRUE)
)
}
}
sensitivity_results <- bind_rows(sensitivity_list)
print("多维敏感性分析结果表：")
print(sensitivity_results)
write.csv(sensitivity_results, "output_figures/Model_Multi_Param_Sensitivity_Results.csv", row.names = FALSE)
p_multi_sensitivity <- ggplot(sensitivity_results, aes(x = Perturbation_Label, y = Mean_Z, group = Parameter_CN, color = Parameter_CN)) +
geom_line(linewidth = 1.2) +
geom_point(size = 4) +
scale_color_viridis_d(option = "turbo", name = "Test Parameter (others baseline)") +
theme_minimal(base_size = 20) +
theme(
plot.title = element_text(size = 28, face = "bold", hjust = 0.5, margin = margin(t=10, b=10)),
plot.subtitle = element_text(size = 18, hjust = 0.5, color = "grey30", margin = margin(b=15)),
axis.title.x = element_text(size = 18, margin = margin(t=10)),
axis.title.y = element_text(size = 18, margin = margin(r=10)),
legend.position = "bottom",
legend.title = element_text(size = 16, face = "bold"),
legend.text = element_text(size = 14),
plot.background = element_rect(fill = "white", color = NA),
panel.background = element_rect(fill = "white", color = NA),
panel.grid.minor = element_blank()
) +
labs(
title = "Z-Model Subjective Parameter Sensitivity Analysis",
subtitle = "Fluctuation of league average tactical value under parameter perturbations of ±20%",
x = "Subjective Parameter Perturbation Ratio",
y = "League Average Tactical Value (Mean Z)"
)
ggsave("output_figures/Model_Sensitivity_Line_Plot.png", plot = p_multi_sensitivity, width = 8, height = 6, dpi = 300, bg="white")
dir.create("data", showWarnings = FALSE)
dir.create("output_figures", showWarnings = FALSE)
# 1. 包加载
library(StatsBombR)
library(tidyverse)
library(ggplot2)
library(gstat)
library(sp)
library(showtext)
# 2. 字体渲染
showtext_auto()
# 3. 颜色卡与断点设定 (全局生效)
my_breaks <- c(-Inf, 0, 2, 4, 6, 8, 10, 12, 15, Inf)
my_colors <- c(
"midnightblue",  # < 0 分 (失误区域)
"blue",          # 0 - 2 分 (后场常规传导)
"dodgerblue",    # 2 - 4 分 (中场过渡)
"cyan",          # 4 - 6 分 (前场推进)
"greenyellow",   # 6 - 8 分 (进入威胁区)
"yellow",        # 8 - 10 分 (关键传球区)
"orange",        # 10 - 12 分 (射门边缘)
"red",           # 12 - 15 分 (高危射门区)
"darkred"        # > 15 分 (绝对得分机会/角球)
)
# 差异图色卡 (红优蓝劣)
diff_breaks <- c(-Inf, -3, -1, 0, 1, 3, Inf)
diff_colors <- c("darkblue", "blue", "lightblue", "lightcoral", "red", "darkred")
# 4. 【核心重构】封装全局足球场辅助线图层 (解耦复用)
get_pitch_lines <- function(line_color = "black") {
list(
annotate("rect", xmin=0, xmax=120, ymin=0, ymax=80, fill=NA, color=line_color, linewidth=0.3),
annotate("segment", x=60, xend=60, y=0, yend=80, color=line_color, linewidth=0.3),
annotate("point", x=60, y=40, color=line_color, size=1.5),
annotate("rect", xmin=0, xmax=18, ymin=18, ymax=62, fill=NA, color=line_color, linewidth=0.3),
annotate("rect", xmin=0, xmax=6, ymin=30, ymax=50, fill=NA, color=line_color, linewidth=0.3),
annotate("point", x=12, y=40, color=line_color, size=1),
annotate("segment", x=0, xend=0, y=36, yend=44, color=line_color, linewidth=1.5),
annotate("rect", xmin=102, xmax=120, ymin=18, ymax=62, fill=NA, color=line_color, linewidth=0.3),
annotate("rect", xmin=114, xmax=120, ymin=30, ymax=50, fill=NA, color=line_color, linewidth=0.3),
annotate("point", x=108, y=40, color=line_color, size=1),
annotate("segment", x=120, xend=120, y=36, yend=44, color=line_color, linewidth=1.5),
coord_fixed(ratio = 1, xlim = c(-1, 121), ylim = c(-1, 81), expand = FALSE)
)
}
# 5. 封装克里金等高线渲染函数
create_pitch_plot <- function(kriging_df, title_text, subtitle_text, save_path) {
p <- ggplot(kriging_df, aes(x = x, y = y, z = var1.pred)) +
geom_contour_filled(breaks = my_breaks) +
scale_fill_manual(values = my_colors, name = "Tactical Value Z", guide = guide_colorsteps(show.limits = TRUE)) +
get_pitch_lines("black") + # <--- 极简调用图层组件！
theme_void() +
theme(
plot.title = element_text(size = 32, face = "bold", hjust = 0.5, margin = margin(t=5, b = 5)),
plot.subtitle = element_text(size = 18, hjust = 0.5, color = "grey20", margin = margin(b = 10)),
legend.title = element_text(size = 14, face = "bold"),
legend.text = element_text(size = 12),
legend.key.height = unit(0.8, "cm"),
plot.background = element_rect(fill = "white", color = NA),
panel.background = element_rect(fill = "white", color = NA),
plot.margin = margin(10, 10, 10, 10)
) +
labs(title = title_text, subtitle = subtitle_text)
ggsave(save_path, plot = p, width = 5, height = 4, units = "in", dpi = 300, bg="white")
return(p)
}
# 抓取全赛季数据
if(!file.exists("data/Bundesliga_1516_AllEvents.rds")) {
print("本地未发现数据，正在从 StatsBomb API 抓取德甲 15/16 数据...")
comp <- FreeCompetitions() %>% filter(competition_name == "1. Bundesliga", season_name == "2015/2016")
matches <- FreeMatches(comp)
all_events_list <- list()
for(i in 1:nrow(matches)) {
tryCatch({
temp_events <- get.matchFree(matches[i,])
all_events_list[[i]] <- temp_events
}, error = function(e) { print(paste("第", i, "场抓取失败跳过")) })
}
all_1516_events <- bind_rows(all_events_list)
saveRDS(all_1516_events, "data/Bundesliga_1516_AllEvents.rds")
} else {
print("从本地读取全赛季原始数据...")
all_1516_events <- readRDS("data/Bundesliga_1516_AllEvents.rds")
}
# 扁平化清洗流
full_season_cleaned <- all_1516_events %>%
allclean() %>%
filter(!type.name %in% c("Starting XI", "Half Start", "Half End")) %>%
mutate(under_pressure = replace_na(under_pressure, FALSE)) %>%
select(
id, match_id, minute, second, team.name,
player.name, position.name,
location.x, location.y, type.id, type.name, under_pressure,
starts_with("pass.height"), pass.type.name, pass.shot_assist,
dribble.outcome.name, pass.outcome.name
) %>%
arrange(match_id, minute, second)
write.csv(full_season_cleaned, "data/Bundesliga_1516_Events.csv", row.names = FALSE)
print(paste("清洗完毕，总行数:", nrow(full_season_cleaned)))
# 计算合成最终价值 Z
def_types <- c("Goal Keeper", "Clearance", "Block", "Interception", "Ball Recovery", "Pressure", "Duel", "Shield", "Foul Committed")
error_types <- c("Miscontrol", "Dispossessed", "Dribbled Past", "Own Goal Against")
final_model_data <- full_season_cleaned %>%
mutate(
custom_type = case_when(
type.name == "Pass" & pass.type.name == "Corner" ~ "Corner",
type.name == "Pass" & pass.type.name == "Free Kick" ~ "Free Kick",
TRUE ~ type.name
),
centrality_score = 1 - (abs(location.y - 40) / 40),
s_base = case_when(
custom_type %in% c("Shot", "Goal Keeper") ~ 10,
custom_type == "Corner" ~ 7,
custom_type == "Free Kick" ~ 6,
type.name == "Pass" & pass.shot_assist == TRUE ~ 8,
custom_type %in% c("Clearance", "Block") ~ 8,
custom_type %in% c("Interception", "Ball Recovery", "Foul Won") ~ 6,
custom_type == "Dribble" & dribble.outcome.name == "Complete" ~ 6,
custom_type %in% c("Duel", "Pressure", "Shield") ~ 4,
custom_type %in% c("Pass", "Carry", "Ball Receipt*") ~ 1,
custom_type %in% error_types ~ -3,
TRUE ~ 1
),
w_space = case_when(
custom_type == "Corner" ~ 2.5,
custom_type == "Free Kick" ~ 2.0,
custom_type %in% error_types ~ 0.5,
custom_type %in% def_types ~ 1 + ((120 - location.x) / 120) + (0.5 * centrality_score),
TRUE ~ 1 + (location.x / 120) + (0.5 * centrality_score)
),
c_pressure = ifelse(under_pressure == TRUE, 1.5, 1.0),
q_height = case_when(
type.name == "Pass" & pass.height.name == "High Pass" ~ 0.8,
type.name == "Pass" & pass.height.name == "Low Pass" ~ 0.9,
TRUE ~ 1.0
),
value_z = s_base * w_space * c_pressure * q_height
) %>% filter(!is.na(value_z))
# 空间网格聚合 (1x1米)
grid_data <- final_model_data %>%
mutate(grid_x = round(location.x), grid_y = round(location.y)) %>%
group_by(grid_x, grid_y) %>%
summarise(avg_z = mean(value_z, na.rm = TRUE), count = n(), .groups = "drop")
# 拟合实验与理论变异函数 (OK)
train_sp <- grid_data
coordinates(train_sp) <- ~grid_x + grid_y
v_emp <- variogram(avg_z ~ 1, train_sp, width = 2, cutoff = 60)
v_model_fitted <- fit.variogram(v_emp, vgm(psill = var(grid_data$avg_z), "Exp", range = 20, nugget = 1))
png("output_figures/Model_Variogram_Fit.png", width = 6, height = 5, units = "in", res = 300)
plot(v_emp, v_model_fitted, main = "Bundesliga Possession Value Variogram Fit")
dev.off()
print("变异函数参数：")
print(v_model_fitted)
# 全场标准化预测基底
pred_grid <- expand.grid(x = 1:120, y = 1:80)
coordinates(pred_grid) <- ~x + y
gridded(pred_grid) <- TRUE
# 5折交叉验证评估与残差直方图
print("正在执行 5折交叉验证...")
cv_results <- krige.cv(avg_z ~ 1, train_sp, model = v_model_fitted, nfold = 5, nmax = 50)
cv_df <- data.frame(Observed = cv_results$observed, Predicted = cv_results$var1.pred, Residuals = cv_results$residual)
p_cv_hist <- ggplot(cv_df, aes(x = Residuals)) +
geom_histogram(aes(y = ..density..), bins = 40, fill = "lightblue", color = "black", alpha = 0.7) +
stat_function(fun = dnorm, args = list(mean = mean(cv_df$Residuals), sd = sd(cv_df$Residuals)), color = "darkred", linewidth = 1.2) +
theme_minimal(base_size = 15) +
theme(plot.background = element_rect(fill="white", color=NA), panel.background = element_rect(fill="white", color=NA)) +
labs(title = "Kriging Prediction Residual Distribution", subtitle="Red line indicates theoretical normal distribution", x = "Prediction Residuals", y = "Density")
ggsave("output_figures/Model_Residual_Histogram.png", plot = p_cv_hist, width = 6, height = 5, dpi = 300, bg="white")
# 封装单一球员处理流 (包含提取、未过滤出图、频次过滤出图)
process_player_kriging <- function(player_string, en_name, position_desc) {
# 提取基础数据
player_base <- final_model_data %>% filter(player.name == player_string) %>%
mutate(grid_x = round(location.x), grid_y = round(location.y)) %>%
group_by(grid_x, grid_y) %>% summarise(avg_z = mean(value_z, na.rm = TRUE), count = n(), .groups = "drop")
# 未过滤场
sp_raw <- player_base
coordinates(sp_raw) <- ~grid_x + grid_y
df_raw <- as.data.frame(krige(avg_z ~ 1, locations = sp_raw, newdata = pred_grid, model = v_model_fitted, nmax = 50))
colnames(df_raw)[which(names(df_raw) == "grid_x")] <- "x"
colnames(df_raw)[which(names(df_raw) == "grid_y")] <- "y"
create_pitch_plot(df_raw, paste0(en_name, " Tactical Value Field (Unfiltered)"), "Unfiltered low-frequency abnormal points", paste0("output_figures/Player_", en_name, "_Unfiltered.png"))
# 频次过滤场 (过滤掉只触球过1-2次的网格，提纯常态表现)
sp_filt <- player_base %>% filter(count >= 3)
coordinates(sp_filt) <- ~grid_x + grid_y
df_filt <- as.data.frame(krige(avg_z ~ 1, locations = sp_filt, newdata = pred_grid, model = v_model_fitted, nmax = 50))
colnames(df_filt)[which(names(df_filt) == "grid_x")] <- "x"
colnames(df_filt)[which(names(df_filt) == "grid_y")] <- "y"
create_pitch_plot(df_filt, paste0(en_name, " Tactical Value Field (Freq >= 3)"), position_desc, paste0("output_figures/Player_", en_name, "_Filtered.png"))
return(df_filt)
}
# 批量执行出图并捕获过滤后的数据用于计算度量
mkhi_df <- process_player_kriging("Henrikh Mkhitaryan", "Mkhitaryan", "Restoring authentic attacking corridor coverage")
auba_df <- process_player_kriging("Pierre-Emerick Aubameyang", "Aubameyang", "Finisher converging in core penalty area")
weigl_df <- process_player_kriging("Julian Weigl", "Weigl", "Deep-lying playmaker covering midfield transition zone")
hummels_df <- process_player_kriging("Mats Hummels", "Hummels", "Defensive leader's passing hot zone across own half")
# ==========================================
# 空间特征量化表导出
# ==========================================
calculate_spatial_metrics <- function(player_df, player_name) {
player_df %>%
summarise(
Player = player_name,
Centroid_X = sum(x * ifelse(var1.pred > 0, var1.pred, 0)) / sum(ifelse(var1.pred > 0, var1.pred, 0)),
Centroid_Y = sum(y * ifelse(var1.pred > 0, var1.pred, 0)) / sum(ifelse(var1.pred > 0, var1.pred, 0)),
High_Threat_Area_sqm = sum(var1.pred > 8),
Zone14_Value = sum(ifelse(x >= 80 & x <= 100 & y >= 30 & y <= 50, var1.pred, 0))
)
}
metrics_table <- bind_rows(
calculate_spatial_metrics(mkhi_df, "Mkhitaryan (CAM)"),
calculate_spatial_metrics(auba_df, "Aubameyang (ST)"),
calculate_spatial_metrics(weigl_df, "Weigl (CDM)"),
calculate_spatial_metrics(hummels_df, "Hummels (CB)")
) %>% mutate(Centroid_X = round(Centroid_X, 1), Centroid_Y = round(Centroid_Y, 1), Zone14_Value = round(Zone14_Value, 0))
write.csv(metrics_table, "output_figures/Player_Core_Spatial_Metrics.csv", row.names = FALSE)
calculate_advanced_metrics <- function(player_df, player_name) {
player_df %>%
mutate(
positive_val = ifelse(var1.pred > 0, var1.pred, 0),
high_threat = var1.pred > 8
) %>%
summarise(
Player = player_name,
# 基础强度
Mean_Value = mean(var1.pred, na.rm = TRUE),
Total_Value = sum(positive_val, na.rm = TRUE),
# 高威胁占比
High_Threat_Ratio = mean(high_threat, na.rm = TRUE),
# 战术重心
Centroid_X = sum(x * positive_val) / sum(positive_val),
Centroid_Y = sum(y * positive_val) / sum(positive_val),
# 前场 vs 后场
Front_Field_Value = sum(ifelse(x >= 80, positive_val, 0)),
Mid_Field_Value   = sum(ifelse(x >= 40 & x < 80, positive_val, 0)),
Back_Field_Value  = sum(ifelse(x < 40, positive_val, 0)),
# Zone14（核心进攻区）
Zone14_Value = sum(ifelse(x >= 80 & x <= 100 & y >= 30 & y <= 50, positive_val, 0))
)
}
advanced_metrics_table <- bind_rows(
calculate_advanced_metrics(mkhi_df, "Mkhitaryan"),
calculate_advanced_metrics(auba_df, "Aubameyang"),
calculate_advanced_metrics(weigl_df, "Weigl"),
calculate_advanced_metrics(hummels_df, "Hummels")
) %>%
mutate(
Centroid_X = round(Centroid_X, 1),
Centroid_Y = round(Centroid_Y, 1),
Mean_Value = round(Mean_Value, 2),
High_Threat_Ratio = round(High_Threat_Ratio, 3)
)
write.csv(advanced_metrics_table, "output_figures/Player_Advanced_Metrics.csv", row.names = FALSE)
# ==========================================
# 2️⃣ 区域占比（论文解释非常有用）
# ==========================================
zone_ratio_table <- advanced_metrics_table %>%
mutate(
Total = Front_Field_Value + Mid_Field_Value + Back_Field_Value,
Front_Ratio = round(Front_Field_Value / Total, 3),
Mid_Ratio   = round(Mid_Field_Value / Total, 3),
Back_Ratio  = round(Back_Field_Value / Total, 3)
) %>%
select(Player, Front_Ratio, Mid_Ratio, Back_Ratio)
write.csv(zone_ratio_table, "output_figures/Player_Zone_Ratio.csv", row.names = FALSE)
# ==========================================
# 3️⃣ 高价值区域分布（空间风险分析）
# ==========================================
high_value_distribution <- function(player_df, player_name) {
player_df %>%
mutate(high_zone = case_when(
var1.pred > 10 ~ "Very High",
var1.pred > 8  ~ "High",
var1.pred > 5  ~ "Medium",
TRUE ~ "Low"
)) %>%
count(high_zone) %>%
mutate(Player = player_name)
}
high_value_table <- bind_rows(
high_value_distribution(mkhi_df, "Mkhitaryan"),
high_value_distribution(auba_df, "Aubameyang"),
high_value_distribution(weigl_df, "Weigl"),
high_value_distribution(hummels_df, "Hummels")
)
write.csv(high_value_table, "output_figures/Player_Value_Distribution.csv", row.names = FALSE)
# ==========================================
# 4️⃣ Top空间热点（论文亮点）
# ==========================================
get_top_hotspots <- function(player_df, player_name) {
player_df %>%
arrange(desc(var1.pred)) %>%
head(10) %>%
mutate(Player = player_name) %>%
select(Player, x, y, var1.pred)
}
top_hotspots <- bind_rows(
get_top_hotspots(mkhi_df, "Mkhitaryan"),
get_top_hotspots(auba_df, "Aubameyang"),
get_top_hotspots(weigl_df, "Weigl"),
get_top_hotspots(hummels_df, "Hummels")
)
write.csv(top_hotspots, "output_figures/Top_Hotspots.csv", row.names = FALSE)
# ==========================================
# 5️⃣ LaTeX三线表输出（论文直接用）
# ==========================================
library(xtable)
latex_table <- xtable(advanced_metrics_table)
print(latex_table,
file = "output_figures/player_metrics_table.tex",
include.rownames = FALSE,
sanitize.text.function = identity)
# ==========================================
# 1️⃣ 构建攻防平衡指标
# ==========================================
calculate_balance_metrics <- function(player_df, player_name) {
df <- player_df %>%
mutate(
val = ifelse(var1.pred > 0, var1.pred, 0),
zone = case_when(
x < 40 ~ "defense",
x < 80 ~ "midfield",
TRUE ~ "attack"
)
)
data.frame(
Player = player_name,
# 攻防分解
Attack_Value = sum(df$val[df$zone == "attack"]),
Midfield_Control = sum(df$val[df$zone == "midfield"]),
Defense_Value = sum(df$val[df$zone == "defense"]),
# 威胁
High_Threat_Ratio = mean(df$var1.pred > 8),
# 稳定性（越低越稳定）
Stability = sd(df$var1.pred, na.rm = TRUE),
# 覆盖范围
Coverage = sum(df$val > 1)
)
}
balance_table <- bind_rows(
calculate_balance_metrics(mkhi_df, "Mkhitaryan"),
calculate_balance_metrics(auba_df, "Aubameyang"),
calculate_balance_metrics(weigl_df, "Weigl"),
calculate_balance_metrics(hummels_df, "Hummels")
)
write.csv(balance_table, "output_figures/Player_Balance_Metrics.csv", row.names = FALSE)
# ==========================================
# 2️⃣ 标准化（用于雷达图）
# ==========================================
library(scales)
radar_data <- balance_table
radar_data_scaled <- radar_data %>%
mutate(across(-Player, ~ rescale(.)))  # 0-1归一化
# ==========================================
# 3️⃣ 雷达图绘制（推荐 ggradar）
# ==========================================
library(ggradar)
install.packages("devtools")
devtools::install_github("ricardo-bion/ggradar")
# ==========================================
# 1️⃣ 构建攻防平衡指标
# ==========================================
calculate_balance_metrics <- function(player_df, player_name) {
df <- player_df %>%
mutate(
val = ifelse(var1.pred > 0, var1.pred, 0),
zone = case_when(
x < 40 ~ "defense",
x < 80 ~ "midfield",
TRUE ~ "attack"
)
)
data.frame(
Player = player_name,
# 攻防分解
Attack_Value = sum(df$val[df$zone == "attack"]),
Midfield_Control = sum(df$val[df$zone == "midfield"]),
Defense_Value = sum(df$val[df$zone == "defense"]),
# 威胁
High_Threat_Ratio = mean(df$var1.pred > 8),
# 稳定性（越低越稳定）
Stability = sd(df$var1.pred, na.rm = TRUE),
# 覆盖范围
Coverage = sum(df$val > 1)
)
}
balance_table <- bind_rows(
calculate_balance_metrics(mkhi_df, "Mkhitaryan"),
calculate_balance_metrics(auba_df, "Aubameyang"),
calculate_balance_metrics(weigl_df, "Weigl"),
calculate_balance_metrics(hummels_df, "Hummels")
)
write.csv(balance_table, "output_figures/Player_Balance_Metrics.csv", row.names = FALSE)
# ==========================================
# 2️⃣ 标准化（用于雷达图）
# ==========================================
library(scales)
radar_data <- balance_table
radar_data_scaled <- radar_data %>%
mutate(across(-Player, ~ rescale(.)))  # 0-1归一化
# ==========================================
# 3️⃣ 雷达图绘制（推荐 ggradar）
# ==========================================
library(ggradar)
library(tibble)
radar_plot_data <- radar_data_scaled %>%
rename(group = Player) %>%
as_tibble()
pdf("output_figures/player_radar_chart.pdf", width = 8, height = 6)
ggradar(radar_plot_data,
grid.min = 0,
grid.mid = 0.5,
grid.max = 1,
legend.position = "right") +
ggtitle("Player Tactical Balance Radar")
dev.off()
